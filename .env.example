NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth0 managed web auth
AUTH0_SECRET=replace-with-32-byte-hex-or-base64-secret
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_BASE_URL=http://localhost:3000
AUTH0_AUDIENCE=https://api.your-voice.example
AUTH0_SCOPE=openid profile email offline_access
AUTH0_ORGANIZATION=
AUTH0_POST_LOGOUT_REDIRECT_URI=http://localhost:3000

# Optional Auth0 Management API for MFA / identity management examples
AUTH0_MGMT_CLIENT_ID=your-auth0-mgmt-client-id
AUTH0_MGMT_CLIENT_SECRET=your-auth0-mgmt-client-secret
AUTH0_MGMT_AUDIENCE=https://your-tenant.eu.auth0.com/api/v2/

# Existing legacy Supabase values kept only until cutover is completed
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# Cleanup and backup scripts
AUTH_BACKUP_DIR=./backups
DATABASE_URL=
SUPABASE_DB_URL=
LEGACY_AUTH_FORCE=0
