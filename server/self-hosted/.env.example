NODE_ENV=development
PORT=4100
APP_BASE_URL=http://localhost:4100
WEB_APP_URL=http://localhost:3000

DATABASE_URL=postgres://your_voice:your_voice@localhost:5432/your_voice
SESSION_TABLE=user_sessions
SESSION_SECRET=replace-with-long-random-secret
CSRF_SECRET=replace-with-another-long-random-secret
AUTH_ENCRYPTION_KEY_BASE64=replace-with-32-byte-base64
PASSWORD_PEPPER=

COOKIE_DOMAIN=
COOKIE_SECURE=false
CORS_ALLOWLIST=http://localhost:3000,http://localhost:4100

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@your-voice.local

JWT_ISSUER=https://auth.your-voice.local
JWT_AUDIENCE=your-voice-api
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=

OIDC_PROVIDER_NAME=google
OIDC_ISSUER=https://accounts.google.com
OIDC_AUTHORIZATION_URL=https://accounts.google.com/o/oauth2/v2/auth
OIDC_TOKEN_URL=https://oauth2.googleapis.com/token
OIDC_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_CALLBACK_URL=http://localhost:4100/api/auth/oauth/google/callback
OIDC_SCOPE=openid profile email
